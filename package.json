{
  "name": "miku-cursor-kit",
  "version": "1.0.6",
  "description": "A standalone Miku themed custom cursor component for React 18+ apps.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/miku-cursor.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --loader .png=dataurl --loader .css=copy",

    "prepare": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NubPlayz/miku-cursor-kit.git"
  },
  "bugs": {
    "url": "https://github.com/NubPlayz/miku-cursor-kit/issues"
  },
  "homepage": "https://github.com/NubPlayz/miku-cursor-kit#readme",
  "author": {
    "name": "NubPlayz",
    "email": "scriptouroboros@gmail.com"
  },
  "keywords": [
    "miku",
    "cursor",
    "custom-cursor",
    "react",
    "react-component",
    "anime",
    "ui"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
